# =============================================================================
# Fitter — Environment Variables
# Copy to .env and fill in production values before deploying.
# =============================================================================

# ── Security & Session ──
SECRET_KEY=                          # REQUIRED. python -c "import secrets; print(secrets.token_urlsafe(32))"
PROFILE_ENCRYPTION_KEY=              # REQUIRED. python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Base de datos local (PostgreSQL en el VPS — primario) ──
DB_USER=rasa_user
DB_PASSWORD=                         # REQUIRED. Elige una contraseña segura
DB_NAME=rasa_db
# Estas dos las construye docker-compose automáticamente con las variables de arriba.
# Solo descoméntalas si arrancas el backend fuera de Docker:
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://rasa_user:PASSWORD@localhost:5432/rasa_db
# RASA_TRACKER_DB=postgresql://rasa_user:PASSWORD@localhost:5432/rasa_db

# ── AWS RDS (backup — NO se usa como primario) ──
# Endpoint de referencia para pg_dump/restore manual o replicación:
# RDS_ENDPOINT=rasa-db-prod.c3s0yagqebxq.us-east-2.rds.amazonaws.com
# RDS_USER=rasa_user
# RDS_PASSWORD=
# RDS_DB=rasa_db

# ── Rasa Connection (overridden in docker-compose, listed for reference) ──
RASA_TIMEOUT_SEND=15
RASA_TIMEOUT_PARSE=10

# ── URLs ──
FRONTEND_URL=https://your-domain.com
BACKEND_BASE_URL=http://backend:5000

# ── CORS ──
CORS_ORIGINS=https://your-domain.com

# ── SMTP (Email Notifications) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_TLS=0
SMTP_USE_SSL=1
SMTP_USERNAME=supporfitter@gmail.com
SMTP_PASSWORD=                       # Gmail App Password
SMTP_DEFAULT_FROM=supporfitter@gmail.com
SMTP_DEFAULT_NAME=Fitter Support

# ── MercadoPago (Payments) ──
MERCADOPAGO_ACCESS_TOKEN=            # Production access token
MERCADOPAGO_PUBLIC_KEY=              # Production public key
MERCADOPAGO_WEBHOOK_SECRET=          # Webhook signature secret
MERCADOPAGO_NOTIFICATION_URL=https://your-domain.com/api/payments/webhook

# ── Google OAuth2 ──
GOOGLE_CLIENT_IDS=                   # Comma-separated list of allowed client IDs
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_VERIFY_MODE=google

# ── Facebook OAuth2 ──
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── Twitter OAuth2 ──
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Chat / Chatbot Context ──
CHAT_CONTEXT_API_KEY=                # Shared key between backend and actions server
BACKEND_CONTEXT_KEY=                 # Same value as CHAT_CONTEXT_API_KEY
CHAT_ENABLE_DIETA_CALC=1
CHAT_DIET_CATALOG=1
# CHAT_DIETA_CALC_MODE=auto          # off | auto | on
# CHAT_REQUIRE_AUTH=1
# CHAT_EMAIL_ROUTINE=1

# ── LLM (Optional — set provider to enable) ──
LLM_PROVIDER=disabled               # disabled | openai | azure
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=900

# ── Embeddings & RAG (Optional) ──
EMBEDDINGS_MODEL=text-embedding-3-small
RAG_INDEX_PATH=./storage/rag_index
RAG_MAX_RESULTS=4

# ── Metrics ──
METRICS_API_KEY=
METRICS_WINDOW_SIZE=500

# ── Frontend (Vite build-time variables) ──
VITE_GOOGLE_CLIENT_ID=
VITE_CHAT_CONTEXT_KEY=
VITE_MP_PUBLIC_KEY=
VITE_FACEBOOK_CLIENT_ID=
